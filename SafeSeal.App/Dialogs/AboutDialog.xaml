<Window x:Class="SafeSeal.App.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SafeSeal"
        Width="460"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource AppBackgroundBrush}"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" Opacity="0.18" ShadowDepth="2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock Text="{Binding AboutTitleText}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <Button DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}">
                        <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPathStyle}" />
                    </Button>
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <Border Width="56" Height="56" CornerRadius="12" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Left">
                        <TextBlock Text="S" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Margin="0,14,0,0" Text="SafeSeal" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding VersionText}" Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding LicenseText}" Foreground="{DynamicResource SecondaryTextBrush}" />

                    <TextBlock Margin="0,14,0,0" Foreground="{DynamicResource AccentBrush}">
                        <Hyperlink NavigateUri="https://github.com" RequestNavigate="Hyperlink_RequestNavigate"> 
                            <Run Text="{Binding GithubText}" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Width="96" Height="36" Content="{Binding CloseText}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CloseCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

