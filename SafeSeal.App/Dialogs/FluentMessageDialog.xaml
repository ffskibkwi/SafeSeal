<Window x:Class="SafeSeal.App.Dialogs.FluentMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="430"
        Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10"
                Padding="18"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" Opacity="0.18" ShadowDepth="2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock Text="{Binding TitleText}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <Button DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}">
                        <Path Data="{StaticResource Icon.Close}" Style="{StaticResource IconPathStyle}" />
                    </Button>
                </DockPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding MessageText}"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="14" />

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="{Binding CloseText}"
                            Width="96"
                            Height="36"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding CloseCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
