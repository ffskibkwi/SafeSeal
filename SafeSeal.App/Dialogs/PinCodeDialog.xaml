<Window x:Class="SafeSeal.App.Dialogs.PinCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="440"
        Height="270"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="10">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.14" ShadowDepth="2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="{Binding PinLabel}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,8" />
                    <UniformGrid Columns="6" HorizontalAlignment="Center">
                        <TextBox x:Name="PinBox1" Tag="0" Style="{DynamicResource PinDigitBoxStyle}" />
                        <TextBox x:Name="PinBox2" Tag="1" Style="{DynamicResource PinDigitBoxStyle}" />
                        <TextBox x:Name="PinBox3" Tag="2" Style="{DynamicResource PinDigitBoxStyle}" />
                        <TextBox x:Name="PinBox4" Tag="3" Style="{DynamicResource PinDigitBoxStyle}" />
                        <TextBox x:Name="PinBox5" Tag="4" Style="{DynamicResource PinDigitBoxStyle}" />
                        <TextBox x:Name="PinBox6" Tag="5" Style="{DynamicResource PinDigitBoxStyle}" />
                    </UniformGrid>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           x:Name="HintText"
                           Text="{Binding PinHint}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="{Binding CancelText}"
                            Width="96"
                            Height="36"
                            Margin="0,0,10,0"
                            IsCancel="True"
                            Style="{StaticResource SecondaryActionButtonStyle}" />
                    <Button Content="{Binding ConfirmText}"
                            Width="96"
                            Height="36"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Confirm_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <Window.Resources>
        <Style x:Key="PinDigitBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MaxLength" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <EventSetter Event="PreviewTextInput" Handler="PinBox_PreviewTextInput" />
            <EventSetter Event="PreviewKeyDown" Handler="PinBox_PreviewKeyDown" />
            <EventSetter Event="TextChanged" Handler="PinBox_TextChanged" />
            <EventSetter Event="DataObject.Pasting" Handler="PinBox_Pasting" />
        </Style>
    </Window.Resources>
</Window>
