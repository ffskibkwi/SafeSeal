<Window x:Class="SafeSeal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SafeSeal.App.ViewModels"
        Title="SafeSeal"
        Height="760"
        Width="1320"
        MinHeight="680"
        MinWidth="1100"
        Background="#F3F3F3">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="SafeSeal" FontSize="26" FontWeight="Bold" Foreground="#2563EB" Margin="6,8,6,18" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Add" Width="72" Margin="0,0,8,0" Command="{Binding AddItemCommand}" />
                        <Button Content="Delete" Width="72" Margin="0,0,8,0" Command="{Binding DeleteItemCommand}" />
                        <Button Content="Rename" Width="72" Command="{Binding RenameItemCommand}" />
                    </StackPanel>
                </StackPanel>

                <ListView ItemsSource="{Binding VaultItems}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="120" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Date Added" Width="95" DisplayMemberBinding="{Binding DateAdded, StringFormat=yyyy-MM-dd}" />
                            <GridViewColumn Header="File Size" Width="65" DisplayMemberBinding="{Binding FileSize}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="24" Background="White" CornerRadius="8" BorderBrush="#E5E5E5" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Live Watermark Preview" FontSize="24" FontWeight="SemiBold" Margin="20,18,20,10" Foreground="#1A1A1A" />

                <Border Grid.Row="1" Margin="20,8,20,20" Background="#FAFAFA" CornerRadius="6" BorderBrush="#E5E5E5" BorderThickness="1">
                    <Grid>
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="14" />
                        <TextBlock Text="Select a .seal file to preview" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8A8A8A">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewImage}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2" Background="White" BorderBrush="#E5E5E5" BorderThickness="1,0,0,0">
            <StackPanel Margin="20,24,20,24">
                <TextBlock Text="Watermark Controls" FontSize="22" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,20" />

                <TextBlock Text="Template" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding TemplateOptions}" SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}" />

                <TextBlock Text="Opacity (10%-40%)" FontWeight="SemiBold" Margin="0,20,0,6" />
                <Slider Minimum="0.1" Maximum="0.4" TickFrequency="0.05" IsSnapToTickEnabled="False" Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{Binding Opacity, StringFormat=F2}" HorizontalAlignment="Right" Margin="0,4,0,0" Foreground="#4B4B4B" />

                <TextBlock Text="Density" FontWeight="SemiBold" Margin="0,20,0,6" />
                <StackPanel Orientation="Vertical">
                    <RadioButton Content="Low" GroupName="Density" IsChecked="{Binding IsLowDensity, Mode=TwoWay}" Margin="0,0,0,6" />
                    <RadioButton Content="Medium" GroupName="Density" IsChecked="{Binding IsMediumDensity, Mode=TwoWay}" Margin="0,0,0,6" />
                    <RadioButton Content="High" GroupName="Density" IsChecked="{Binding IsHighDensity, Mode=TwoWay}" />
                </StackPanel>

                <Button Content="Export" Height="42" Margin="0,36,0,0" Background="#2563EB" Foreground="White" Command="{Binding ExportCommand}" />

                <TextBlock Text="Working..." Margin="0,18,0,0" Foreground="#2563EB" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
