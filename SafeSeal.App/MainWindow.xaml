<Window x:Class="SafeSeal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SafeSeal.App.ViewModels"
        Title="SafeSeal"
        Height="760"
        Width="1320"
        MinHeight="680"
        MinWidth="1080"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="SafeSeal"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Private document vault"
                               Foreground="#6B7280"
                               Margin="0,0,0,24" />

                    <Button Content="Import"
                            Command="{Binding ImportCommand}"
                            Height="40"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0">
                    <TextBlock Text="Items"
                               FontWeight="SemiBold"
                               Foreground="#374151"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Documents.Count, StringFormat={}{0} secure documents}"
                               Foreground="#6B7280" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="18"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="My Documents"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               Margin="4,2,4,14" />

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Documents}"
                                 SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="8" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="230"
                                            Height="140"
                                            Background="White"
                                            CornerRadius="8"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            Padding="14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" Opacity="0.08" ShadowDepth="2" />
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="#111827"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding UpdatedDisplay}"
                                                           Foreground="#6B7280"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Content="Rename"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="Delete"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="Transparent"
                                IsHitTestVisible="False">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No documents yet"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="#4B5563" />
                                <TextBlock Text="Import a photo to create your first secure item."
                                           Margin="0,6,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#6B7280" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Width="400"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="White"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Opacity="0"
                    Panel.ZIndex="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" Opacity="0.13" ShadowDepth="4" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform X="420" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailPaneOpen}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0"
                                                             Duration="0:0:0.20"
                                                             FillBehavior="HoldEnd" />
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18"
                                                             FillBehavior="HoldEnd" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="420"
                                                             Duration="0:0:0.18"
                                                             FillBehavior="HoldEnd" />
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.15"
                                                             FillBehavior="HoldEnd" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Watermark"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1A1A1A" />

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,12"
                               Text="{Binding SelectedDocument.DisplayName}"
                               FontWeight="SemiBold"
                               Foreground="#4B5563" />

                    <Border Grid.Row="2"
                            Height="230"
                            CornerRadius="8"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1"
                            Background="#F8FAFC"
                            Margin="0,0,0,12"
                            ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="10" />
                            <TextBlock Text="Live Preview"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#94A3B8"
                                       Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <Button Grid.Row="3"
                            Content=">>"
                            Width="24"
                            Height="56"
                            FontSize="13"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-8,-16,0"
                            Foreground="#98A2B3"
                            Style="{StaticResource CollapseToggleButtonStyle}"
                            Panel.ZIndex="30"
                            Command="{Binding CloseDetailCommand}" />

                    <ScrollViewer Grid.Row="3"
                                  Margin="0,8,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource FluentScrollBarStyle}" />
                        </ScrollViewer.Resources>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Template" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding Templates}"
                                      SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}" />

                            <StackPanel Visibility="{Binding IsTemplateFieldSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding TemplateFields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="34"
                                                         Padding="10,0"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsCustomTemplateSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,12,0,0">
                                <TextBlock Text="Text Lines" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ComboBox ItemsSource="{Binding LineCountOptions}"
                                          SelectedItem="{Binding SelectedLineCount, Mode=TwoWay}" />

                                <ItemsControl ItemsSource="{Binding WatermarkLines}" Margin="0,10,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="34"
                                                         Padding="10,0"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Text="Tint" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <ComboBox ItemsSource="{Binding TintOptions}"
                                      SelectedItem="{Binding SelectedTintOption, Mode=TwoWay}"
                                      DisplayMemberPath="Name" />

                            <TextBlock Text="Opacity" FontWeight="SemiBold" Margin="0,14,0,6" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="0.05"
                                    Maximum="0.85"
                                    Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding Opacity, StringFormat=F2}"
                                       HorizontalAlignment="Right"
                                       Foreground="#64748B" />

                            <TextBlock Text="Font Size" FontWeight="SemiBold" Margin="0,14,0,6" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="10"
                                    Maximum="72"
                                    Value="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding FontSize, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="#64748B" />

                            <TextBlock Text="Horizontal Spacing" FontWeight="SemiBold" Margin="0,14,0,6" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="80"
                                    Maximum="700"
                                    Value="{Binding HorizontalSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding HorizontalSpacing, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="#64748B" />

                            <TextBlock Text="Vertical Spacing" FontWeight="SemiBold" Margin="0,14,0,6" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="80"
                                    Maximum="700"
                                    Value="{Binding VerticalSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding VerticalSpacing, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="#64748B" />

                            <TextBlock Text="Angle" FontWeight="SemiBold" Margin="0,14,0,6" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="0"
                                    Maximum="360"
                                    Value="{Binding AngleDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding AngleDegrees, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="#64748B" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" Margin="0,16,0,0">
                        <Button Content="Export"
                                Height="40"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        <TextBlock Text="Working..."
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,6,0,0"
                                   Foreground="#475569" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
