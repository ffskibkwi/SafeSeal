<Window x:Class="SafeSeal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SafeSeal.App.ViewModels"
        Title="{Binding AppTitleText}"
        Height="760"
        Width="1320"
        MinHeight="680"
        MinWidth="1120"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="Width" Value="220" />
            <Setter Property="Height" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style x:Key="SidebarPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="220" />
            <Setter Property="Height" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="{Binding AppTitleText}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding AppSubtitleText}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,20"
                               TextWrapping="Wrap" />

                    <Button Command="{Binding ImportCommand}"
                            Style="{StaticResource SidebarPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Import}" Style="{StaticResource IconPathStyle}" Stroke="White" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ImportText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ToggleBatchModeCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Batch}" Style="{StaticResource IconPathStyle}" Stroke="{DynamicResource MutedTextBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding BatchModeButtonText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RunBatchProcessCommand}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Visibility="{Binding IsBatchRunVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Batch}" Style="{StaticResource IconPathStyle}" Stroke="{DynamicResource AccentBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding RunBatchText}" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Margin="0,18,0,6"
                               Text="{Binding TransferText}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontWeight="SemiBold" />

                    <Button Command="{Binding CreateArchiveCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.TransferCreate}" Style="{StaticResource IconPathStyle}" Stroke="{DynamicResource MutedTextBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding CreateTransferText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding LoadArchiveCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.TransferLoad}" Style="{StaticResource IconPathStyle}" Stroke="{DynamicResource MutedTextBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding LoadTransferText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,24,0,0">
                    <Button Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Settings}" Style="{StaticResource IconPathStyle}" Stroke="{DynamicResource MutedTextBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding SettingsText}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding SecureDocumentsText}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,10,0,0" />
                    <TextBlock Text="{Binding SelectedForBulkText}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0"
                               Visibility="{Binding IsBatchRunVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="18"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding MyDocumentsText}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="4,2,4,14" />

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Documents}"
                                 SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="8" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="230"
                                            Height="140"
                                            CornerRadius="8"
                                            Padding="14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsBatchSelected}" Value="True" />
                                                            <Condition Binding="{Binding DataContext.IsBatchModeEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                        <Setter Property="Background" Value="#122563EB" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" Opacity="0.08" ShadowDepth="2" />
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Margin="0,0,0,0">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding UpdatedDisplay}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding DataContext.RenameText, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                </Button>
                                                <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource Icon.Delete}" Style="{StaticResource IconPathStyle}" Stroke="{DynamicResource DangerBrush}" Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding DataContext.DeleteActionText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   Foreground="{DynamicResource DangerBrush}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="Transparent"
                                IsHitTestVisible="False">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding NoDocumentsText}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding NoDocumentsHintText}"
                                           Margin="0,6,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Width="400"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Opacity="0"
                    Panel.ZIndex="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" Opacity="0.13" ShadowDepth="4" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform X="420" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailPaneOpen}" Value="True">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0"
                                                             Duration="0:0:0.20"
                                                             FillBehavior="HoldEnd" />
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18"
                                                             FillBehavior="HoldEnd" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="420"
                                                             Duration="0:0:0.18"
                                                             FillBehavior="HoldEnd" />
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.15"
                                                             FillBehavior="HoldEnd" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding WatermarkText}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,12"
                               Text="{Binding SelectedDocument.DisplayName}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}" />

                    <Border Grid.Row="2"
                            Height="230"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource AppBackgroundBrush}"
                            Margin="0,0,0,12"
                            ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="10" />
                            <TextBlock Text="{Binding LivePreviewText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <Button Grid.Row="3"
                            Width="24"
                            Height="56"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-8,-16,0"
                            Style="{StaticResource CollapseToggleButtonStyle}"
                            Panel.ZIndex="30"
                            Command="{Binding CloseDetailCommand}"
                            Opacity="0.55">
                    </Button>

                    <ScrollViewer Grid.Row="3"
                                  Margin="0,8,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource FluentScrollBarStyle}" />
                        </ScrollViewer.Resources>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="{Binding TemplateText}" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <ItemsControl ItemsSource="{Binding Templates}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton Content="{Binding Name}"
                                                     GroupName="TemplateGroup"
                                                     Style="{StaticResource ModernBulletRadioStyle}"
                                                     Command="{Binding DataContext.SelectTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     CommandParameter="{Binding}">
                                            <RadioButton.IsChecked>
                                                <MultiBinding Mode="OneWay" Converter="{StaticResource EqualityMultiConverter}">
                                                    <Binding Path="DataContext.SelectedTemplate" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding />
                                                </MultiBinding>
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Visibility="{Binding IsTemplateFieldSectionVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,10,0,0">
                                <ItemsControl ItemsSource="{Binding TemplateFields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="34"
                                                         Padding="10,0"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsCustomTemplateSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,12,0,0">
                                <TextBlock Text="{Binding TextLinesText}" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                                <ItemsControl ItemsSource="{Binding LineCountOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton Content="{Binding}"
                                                         GroupName="LineCountGroup"
                                                         Style="{StaticResource ModernBulletRadioStyle}"
                                                         Command="{Binding DataContext.SelectLineCountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         CommandParameter="{Binding}">
                                                <RadioButton.IsChecked>
                                                    <MultiBinding Mode="OneWay" Converter="{StaticResource EqualityMultiConverter}">
                                                        <Binding Path="DataContext.SelectedLineCount" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </RadioButton.IsChecked>
                                            </RadioButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding WatermarkLines}" Margin="0,10,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="34"
                                                         Padding="10,0"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Text="{Binding TintText}" FontWeight="SemiBold" Margin="0,10,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <ItemsControl ItemsSource="{Binding TintOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton Content="{Binding Name}"
                                                     GroupName="TintGroup"
                                                     Style="{StaticResource ModernBulletRadioStyle}"
                                                     Command="{Binding DataContext.SelectTintOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     CommandParameter="{Binding}">
                                            <RadioButton.IsChecked>
                                                <MultiBinding Mode="OneWay" Converter="{StaticResource EqualityMultiConverter}">
                                                    <Binding Path="DataContext.SelectedTintOption" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding />
                                                </MultiBinding>
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding OpacityText}" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="0.05"
                                    Maximum="0.85"
                                    Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding Opacity, StringFormat=F2}"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}" />

                            <TextBlock Text="{Binding FontSizeText}" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="10"
                                    Maximum="72"
                                    Value="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding FontSize, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}" />

                            <TextBlock Text="{Binding HorizontalSpacingText}" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="80"
                                    Maximum="700"
                                    Value="{Binding HorizontalSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding HorizontalSpacing, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}" />

                            <TextBlock Text="{Binding VerticalSpacingText}" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="80"
                                    Maximum="700"
                                    Value="{Binding VerticalSpacing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding VerticalSpacing, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}" />

                            <TextBlock Text="{Binding AngleText}" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <Slider Style="{StaticResource ModernSliderStyle}"
                                    Minimum="0"
                                    Maximum="360"
                                    Value="{Binding AngleDegrees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding AngleDegrees, StringFormat=F0}"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedTextBrush}" />

                            <TextBlock Text="{Binding ValidityText}" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{Binding ValidityNoneText}" GroupName="ValidityGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsValidityNone, Mode=TwoWay}" />
                                <RadioButton Content="{Binding ValidityDateText}" GroupName="ValidityGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsValidityDate, Mode=TwoWay}" />
                                <RadioButton Content="{Binding ValidityExpiryDateText}" GroupName="ValidityGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsValidityExpiryDate, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0" Visibility="{Binding IsDateOptionsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding DateOptionsText}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="{Binding TodayText}" GroupName="DatePresetGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsDatePresetToday, Mode=TwoWay}" />
                                    <RadioButton Content="{Binding CustomText}" GroupName="DatePresetGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsDatePresetCustom, Mode=TwoWay}" />
                                </StackPanel>
                                <TextBox Margin="0,4,0,0"
                                         Height="34"
                                         Padding="10,0"
                                         VerticalContentAlignment="Center"
                                         Visibility="{Binding IsDateCustomVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Text="{Binding CustomDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0" Visibility="{Binding IsExpiryOptionsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding ExpiryOptionsText}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4" />
                                <WrapPanel>
                                    <RadioButton Content="{Binding TodayText}" GroupName="ExpiryPresetGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsExpiryPresetToday, Mode=TwoWay}" />
                                    <RadioButton Content="{Binding ThisWeekText}" GroupName="ExpiryPresetGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsExpiryPresetThisWeek, Mode=TwoWay}" />
                                    <RadioButton Content="{Binding ThisMonthText}" GroupName="ExpiryPresetGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsExpiryPresetThisMonth, Mode=TwoWay}" />
                                    <RadioButton Content="{Binding CustomText}" GroupName="ExpiryPresetGroup" Style="{StaticResource ModernBulletRadioStyle}" IsChecked="{Binding IsExpiryPresetCustom, Mode=TwoWay}" />
                                </WrapPanel>
                                <TextBox Margin="0,4,0,0"
                                         Height="34"
                                         Padding="10,0"
                                         VerticalContentAlignment="Center"
                                         Visibility="{Binding IsExpiryCustomVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                         Text="{Binding CustomExpiryDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" Margin="0,16,0,0">
                        <Button Content="{Binding ExportText}"
                                Height="40"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        <TextBlock Text="{Binding WorkingText}"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>










